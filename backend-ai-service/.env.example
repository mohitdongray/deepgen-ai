# DeepGen AI Service
APP_NAME=DeepGen AI
APP_VERSION=2.0.0
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

JOBS_FILE=jobs.json
OUTPUTS_DIR=outputs

HTTP_TIMEOUT=90
HTTP_CONNECT_TIMEOUT=10
DOWNLOAD_TIMEOUT=120
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=30.0

# ── Primary image providers (chain: Qwen → Flux) ─────────────────────
# Qwen / DashScope — use either name
QWEN_API_KEY=
# DASHSCOPE_API_KEY=

QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_MODEL=qwen-image-2.0-pro
QWEN_IMAGE_SIZE=1024*1024
QWEN_TIMEOUT=120

# FLUX / Black Forest Labs — use either name
FLUX_API_KEY=
# BFL_API_KEY=

FLUX_BASE_URL=https://api.bfl.ai
FLUX_MODEL_ENDPOINT=v1/flux-pro-1.1
FLUX_WIDTH=1024
FLUX_HEIGHT=1024
FLUX_POLL_INTERVAL=1
FLUX_MAX_POLLS=120

# ── Video / avatar provider ───────────────────────────────────────────
TAVUS_API_KEY=
TAVUS_REPLICA_ID=r79e1c033f
TAVUS_POLL_INTERVAL=5
TAVUS_MAX_POLLS=30
