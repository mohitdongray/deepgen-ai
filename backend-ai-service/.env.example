# Python AI Service Environment Configuration

# Service Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=info

# External AI API Keys (required for actual generation)
# Get keys from respective provider dashboards:
# - HeyGen: https://app.heygen.com/settings/api
# - Tavus: https://app.tavus.io/settings
# - HuggingFace: https://huggingface.co/settings/tokens
# - Replicate: https://replicate.com/account/api-tokens
# - DeepAI: https://deepai.org/api

HEYGEN_API_KEY=your-heygen-api-key
TAVUS_API_KEY=your-tavus-api-key
HUGGINGFACE_TOKEN=your-huggingface-token
REPLICATE_API_TOKEN=your-replicate-token
DEEPAI_API_KEY=your-deepai-api-key

# Redis Configuration (for production job storage)
REDIS_URL=redis://localhost:6379

# Storage Configuration
# Local path or cloud storage (S3, GCS, Azure)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
