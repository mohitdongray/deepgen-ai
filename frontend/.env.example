# Gateway URL (all API calls go here — NOT directly to FastAPI)
REACT_APP_GATEWAY_URL=https://deepgen-gateway.onrender.com
REACT_APP_API_URL=http://localhost:5000

# Vite-style alias (optional, used if REACT_APP_GATEWAY_URL/REACT_APP_API_URL is unset)
VITE_API_URL=https://deepgen-gateway.onrender.com
VITE_BACKEND_URL=http://localhost:5000

REACT_APP_ENV=development
REACT_APP_ENABLE_ANALYTICS=false
